<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>لحظة | كاميرا مباشرة</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', 'Tajawal', sans-serif;
      background: #000;
      height: 100vh;
      width: 100vw;
      overflow: hidden;
      color: white;
      direction: rtl;
    }

    .app-container {
      width: 100%;
      height: 100vh;
      position: relative;
      background: #000;
      display: flex;
      flex-direction: column;
    }

    /* شريط الحالة العلوي */
    .status-bar {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      z-index: 20;
      padding: 16px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, transparent 100%);
    }

    .back-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(10px);
      border: none;
      color: white;
      font-size: 1.2rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s;
    }

    .back-btn:hover {
      background: rgba(255,255,255,0.25);
    }

    .grid-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(10px);
      border: none;
      color: white;
      font-size: 1.1rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s;
    }

    .grid-btn:hover {
      background: rgba(255,255,255,0.25);
    }

    /* منطقة الكاميرا */
    .camera-view {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #111;
    }

    #cameraVideo {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    #imagePreview {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: none;
      position: absolute;
      top: 0;
      left: 0;
      z-index: 2;
      background: #000;
    }

    /* شبكة التصوير */
    .grid-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 3;
      display: none;
    }

    .grid-overlay.active {
      display: block;
    }

    .grid-line {
      position: absolute;
      background: rgba(255,255,255,0.3);
    }

    .grid-line.horizontal {
      left: 0;
      width: 100%;
      height: 1px;
    }

    .grid-line.vertical {
      top: 0;
      width: 1px;
      height: 100%;
    }

    /* رسالة تنبيهية */
    .toast {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: rgba(0,0,0,0.85);
      backdrop-filter: blur(20px);
      padding: 12px 24px;
      border-radius: 25px;
      font-size: 0.9rem;
      z-index: 25;
      opacity: 0;
      transition: opacity 0.3s;
      pointer-events: none;
      white-space: nowrap;
      border: 1px solid rgba(255,255,255,0.2);
    }

    .toast.show {
      opacity: 1;
    }

    .toast.error {
      border-color: #ff5252;
      color: #ffb3b3;
    }

    .toast.success {
      border-color: #2ecc71;
      color: #b3ffe0;
    }

    /* زر التقاط الصورة */
    .capture-zone {
      position: absolute;
      bottom: 120px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 15;
      display: flex;
      align-items: center;
      gap: 30px;
    }

    .capture-btn {
      width: 75px;
      height: 75px;
      border-radius: 50%;
      background: white;
      border: 4px solid rgba(255,255,255,0.5);
      box-shadow: 0 0 0 6px rgba(255,255,255,0.15);
      cursor: pointer;
      transition: all 0.2s;
      position: relative;
    }

    .capture-btn:active {
      transform: scale(0.85);
      box-shadow: 0 0 0 10px rgba(255,255,255,0.2);
    }

    .capture-btn::after {
      content: '';
      position: absolute;
      top: -8px;
      left: -8px;
      right: -8px;
      bottom: -8px;
      border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.3);
    }

    .capture-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* ركن المعرض */
    .gallery-preview {
      width: 45px;
      height: 45px;
      border-radius: 10px;
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(10px);
      border: 2px solid rgba(255,255,255,0.3);
      cursor: pointer;
      overflow: hidden;
      transition: all 0.3s;
    }

    .gallery-preview:hover {
      border-color: rgba(255,255,255,0.6);
    }

    .gallery-preview img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* البانل السفلي */
    .bottom-sheet {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: rgba(10, 5, 20, 0.85);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
      border-top: 1px solid rgba(255,255,255,0.1);
      padding: 16px 20px 24px;
      z-index: 10;
      border-radius: 25px 25px 0 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    /* مربع الكتابة */
    .message-container {
      display: flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 25px;
      padding: 4px 16px 4px 4px;
    }

    .attach-icon {
      background: none;
      border: none;
      color: rgba(255,255,255,0.7);
      font-size: 1.4rem;
      cursor: pointer;
      padding: 8px;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .attach-icon:hover {
      color: white;
      transform: scale(1.1);
    }

    #messageBox {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      padding: 12px 4px;
      font-size: 15px;
      color: white;
      font-family: inherit;
      resize: none;
      height: 44px;
      line-height: 1.4;
    }

    #messageBox::placeholder {
      color: rgba(255,255,255,0.4);
    }

    .send-btn {
      background: linear-gradient(135deg, #7c3aed, #a855f7);
      border: none;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: white;
      transition: all 0.3s;
      flex-shrink: 0;
    }

    .send-btn:hover {
      background: linear-gradient(135deg, #8b5cf6, #c084fc);
      box-shadow: 0 4px 15px rgba(124, 58, 237, 0.6);
    }

    .send-btn:active {
      transform: scale(0.9);
    }

    .send-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    /* مؤشر الصورة المرفقة */
    .image-indicator {
      display: none;
      align-items: center;
      gap: 8px;
      background: rgba(124, 58, 237, 0.2);
      border: 1px solid rgba(124, 58, 237, 0.4);
      border-radius: 20px;
      padding: 6px 14px;
      font-size: 0.85rem;
    }

    .image-indicator.active {
      display: flex;
    }

    .remove-image {
      background: rgba(255,255,255,0.1);
      border: none;
      color: white;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 0.8rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Progress Bar */
    .progress-container {
      width: 100%;
      height: 3px;
      background: rgba(255,255,255,0.1);
      border-radius: 2px;
      overflow: hidden;
      display: none;
    }

    .progress-container.active {
      display: block;
    }

    .progress-bar {
      height: 100%;
      background: linear-gradient(90deg, #7c3aed, #a855f7);
      border-radius: 2px;
      width: 0%;
      transition: width 0.3s ease;
    }

    /* Loader */
    .loader {
      display: inline-block;
      width: 18px;
      height: 18px;
      border: 2px solid rgba(255,255,255,0.3);
      border-radius: 50%;
      border-top-color: #fff;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    #imageInput {
      display: none;
    }

    @media (max-width: 400px) {
      .capture-btn {
        width: 65px;
        height: 65px;
      }
      
      .bottom-sheet {
        padding: 12px 16px 20px;
      }
    }
  </style>
</head>
<body>
  <div class="app-container">
    <!-- شريط الحالة -->
    <div class="status-bar">
      <button class="back-btn" id="backButton" title="رجوع">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
      </button>
      
      <button class="grid-btn" id="gridBtn" title="شبكة التصوير">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7"/>
          <rect x="14" y="3" width="7" height="7"/>
          <rect x="3" y="14" width="7" height="7"/>
          <rect x="14" y="14" width="7" height="7"/>
        </svg>
      </button>
    </div>

    <!-- منطقة الكاميرا -->
    <div class="camera-view" id="cameraView">
      <video id="cameraVideo" autoplay playsinline muted></video>
      <img id="imagePreview" alt="معاينة الصورة" />
      
      <!-- شبكة التصوير -->
      <div class="grid-overlay" id="gridOverlay">
        <div class="grid-line horizontal" style="top: 33.33%"></div>
        <div class="grid-line horizontal" style="top: 66.66%"></div>
        <div class="grid-line vertical" style="left: 33.33%"></div>
        <div class="grid-line vertical" style="left: 66.66%"></div>
      </div>
    </div>

    <!-- رسالة تنبيه -->
    <div class="toast" id="toast"></div>

    <!-- منطقة الالتقاط -->
    <div class="capture-zone">
      <label for="imageInput" class="gallery-preview" id="galleryPreview" title="آخر صورة">
        <img src="" alt="معرض" id="galleryThumb" style="display:none;">
      </label>
      
      <button class="capture-btn" id="captureButton" title="التقاط صورة"></button>
      
      <div style="width:45px;"></div>
    </div>

    <!-- البانل السفلي -->
    <div class="bottom-sheet">
      <!-- مؤشر الصورة المرفقة -->
      <div class="image-indicator" id="imageIndicator">
        <span>📸 تم التقاط صورة</span>
        <button class="remove-image" id="removeImageBtn">✕</button>
      </div>

      <!-- شريط التقدم -->
      <div class="progress-container" id="progressContainer">
        <div class="progress-bar" id="progressBar"></div>
      </div>

      <!-- مربع الكتابة -->
      <div class="message-container">
        <button class="attach-icon" id="attachBtn" title="اختيار من المعرض">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/>
          </svg>
        </button>
        
        <textarea 
          id="messageBox" 
          placeholder="اكتب تعليقك هنا..."
          maxlength="500"
        ></textarea>
        
        <button class="send-btn" id="sendButton" title="إرسال">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </button>
      </div>
    </div>

    <input type="file" id="imageInput" accept="image/*" capture="environment">
  </div>

  <script>
    // ============================================
    // لحظة كام - الإصدار النهائي
    // ============================================

    class LahzaCam {
      constructor() {
        // العناصر
        this.cameraVideo = document.getElementById('cameraVideo');
        this.imagePreview = document.getElementById('imagePreview');
        this.imageInput = document.getElementById('imageInput');
        this.captureButton = document.getElementById('captureButton');
        this.backButton = document.getElementById('backButton');
        this.sendButton = document.getElementById('sendButton');
        this.messageBox = document.getElementById('messageBox');
        this.attachBtn = document.getElementById('attachBtn');
        this.removeImageBtn = document.getElementById('removeImageBtn');
        this.imageIndicator = document.getElementById('imageIndicator');
        this.galleryThumb = document.getElementById('galleryThumb');
        this.gridBtn = document.getElementById('gridBtn');
        this.gridOverlay = document.getElementById('gridOverlay');
        this.toast = document.getElementById('toast');
        this.progressContainer = document.getElementById('progressContainer');
        this.progressBar = document.getElementById('progressBar');

        // الحالة
        this.currentStream = null;
        this.facingMode = 'environment';
        this.capturedImageData = null;
        this.isSubmitting = false;
        this.maxRetries = 3;
        this.retryCount = 0;
        this.requestTimeout = 30000; // 30 ثانية

        // بدء التشغيل
        this.init();
      }

      init() {
        this.setupEventListeners();
        this.startCamera('environment');
      }

      // ========== وظائف مساعدة ==========
      showToast(message, type = 'info', duration = 3000) {
        const toast = this.toast;
        if (!toast) return;

        toast.textContent = message;
        toast.className = `toast show ${type}`;

        clearTimeout(this._toastTimeout);
        this._toastTimeout = setTimeout(() => {
          toast.className = 'toast';
        }, duration);
      }

      showProgress(show) {
        if (this.progressContainer) {
          this.progressContainer.classList.toggle('active', show);
        }
        if (this.progressBar && !show) {
          this.progressBar.style.width = '0%';
        }
      }

      updateProgress(percent) {
        if (this.progressBar) {
          this.progressBar.style.width = `${Math.min(100, percent)}%`;
        }
      }

      setSubmitting(loading) {
        this.isSubmitting = loading;
        const btn = this.sendButton;
        if (!btn) return;

        if (loading) {
          btn.disabled = true;
          btn.dataset.originalHTML = btn.innerHTML;
          btn.innerHTML = '<span class="loader"></span>';
        } else {
          btn.disabled = false;
          btn.innerHTML = btn.dataset.originalHTML || btn.innerHTML;
          delete btn.dataset.originalHTML;
        }
      }

      // ========== الكاميرا ==========
      async startCamera(mode = 'environment') {
        if (this.currentStream) {
          this.currentStream.getTracks().forEach(track => track.stop());
        }
        
        try {
          const stream = await navigator.mediaDevices.getUserMedia({
            video: { 
              facingMode: mode, 
              width: { ideal: 1280 }, 
              height: { ideal: 720 } 
            },
            audio: false
          });
          
          this.cameraVideo.srcObject = stream;
          this.currentStream = stream;
          this.facingMode = mode;
          
          this.cameraVideo.style.display = 'block';
          this.imagePreview.style.display = 'none';
        } catch (err) {
          console.error('خطأ في الكاميرا:', err);
          this.showToast('⚠️ تعذر الوصول إلى الكاميرا', 'error');
          this.cameraVideo.style.display = 'none';
        }
      }

      // ========== التقاط الصورة ==========
      captureImage() {
        if (!this.currentStream || this.cameraVideo.videoWidth === 0) {
          this.showToast('الكاميرا غير جاهزة بعد', 'error');
          return;
        }

        const canvas = document.createElement('canvas');
        canvas.width = this.cameraVideo.videoWidth;
        canvas.height = this.cameraVideo.videoHeight;
        const ctx = canvas.getContext('2d');
        
        // عكس الصورة إذا كانت الكاميرا الأمامية
        if (this.facingMode === 'user') {
          ctx.translate(canvas.width, 0);
          ctx.scale(-1, 1);
        }
        
        ctx.drawImage(this.cameraVideo, 0, 0, canvas.width, canvas.height);
        
        // ضغط الصورة للحجم المناسب
        this.capturedImageData = this.compressImage(canvas);
        
        // عرض الصورة
        this.imagePreview.src = this.capturedImageData;
        this.imagePreview.style.display = 'block';
        this.cameraVideo.style.display = 'none';
        
        // تحديث المعرض المصغر
        this.galleryThumb.src = this.capturedImageData;
        this.galleryThumb.style.display = 'block';
        
        // إظهار مؤشر الصورة
        this.imageIndicator.classList.add('active');
        
        this.showToast('📸 تم الالتقاط!', 'success');
      }

      // ========== ضغط الصورة ==========
      compressImage(canvas, targetSizeMB = 1.5) {
        let quality = 0.85;
        let dataUrl = canvas.toDataURL('image/jpeg', quality);
        const maxBytes = targetSizeMB * 1024 * 1024 * 1.33; // base64 overhead

        while (dataUrl.length > maxBytes && quality > 0.5) {
          quality -= 0.08;
          dataUrl = canvas.toDataURL('image/jpeg', quality);
        }

        if (dataUrl.length > maxBytes && canvas.width > 1200) {
          const scaleFactor = Math.sqrt(maxBytes / dataUrl.length);
          const scaledCanvas = document.createElement('canvas');
          scaledCanvas.width = Math.round(canvas.width * scaleFactor);
          scaledCanvas.height = Math.round(canvas.height * scaleFactor);
          const scaledCtx = scaledCanvas.getContext('2d');
          scaledCtx.drawImage(canvas, 0, 0, scaledCanvas.width, scaledCanvas.height);
          dataUrl = scaledCanvas.toDataURL('image/jpeg', 0.75);
        }

        return dataUrl;
      }

      // ========== رفع من المعرض ==========
      handleFileUpload(file) {
        if (!file || !file.type.startsWith('image/')) {
          this.showToast('الرجاء اختيار ملف صورة صالح', 'error');
          return;
        }

        if (file.size > 20 * 1024 * 1024) {
          this.showToast('حجم الملف كبير جداً. الحد الأقصى 20 ميجابايت', 'error');
          return;
        }

        const reader = new FileReader();
        reader.onload = (e) => {
          // عرض الصورة كما هي بدون تحسين
          this.capturedImageData = e.target.result;
          
          this.imagePreview.src = this.capturedImageData;
          this.imagePreview.style.display = 'block';
          this.cameraVideo.style.display = 'none';
          
          this.galleryThumb.src = this.capturedImageData;
          this.galleryThumb.style.display = 'block';
          
          this.imageIndicator.classList.add('active');
          this.showToast('🖼️ تم تحميل الصورة', 'success');
        };
        reader.onerror = () => {
          this.showToast('فشل قراءة الملف', 'error');
        };
        reader.readAsDataURL(file);
      }

      // ========== العودة للكاميرا ==========
      returnToCamera() {
        this.imagePreview.style.display = 'none';
        this.cameraVideo.style.display = 'block';
        this.imageIndicator.classList.remove('active');
        this.capturedImageData = null;
        this.imageInput.value = '';
        
        if (!this.currentStream || this.currentStream.getVideoTracks()[0].readyState === 'ended') {
          this.startCamera(this.facingMode);
        }
      }

      // ========== الإرسال - المهمة الأساسية ==========
      async handleSend() {
        if (this.isSubmitting) return;

        const message = this.messageBox.value.trim();
        const hasImage = this.capturedImageData ? true : false;
        
        if (!hasImage && message === '') {
          this.showToast('✨ التقط صورة أو اكتب رسالة', 'info');
          return;
        }

        // تجهيز البيانات للإرسال
        const payload = {
          text: message || 'استخراج بيانات الفاتورة',
          image: hasImage ? this.capturedImageData : null,
          timestamp: Date.now()
        };

        // بدء عملية الإرسال مع إعادة المحاولة
        this.retryCount = 0;
        await this.submitWithRetry(payload);
      }

      async submitWithRetry(payload) {
        this.setSubmitting(true);
        this.showProgress(true);
        this.updateProgress(10);

        try {
          const result = await this.sendToAI(payload);
          this.handleSubmitSuccess(result);
        } catch (error) {
          console.error('Submit error:', error);

          if (this.retryCount < this.maxRetries) {
            this.retryCount++;
            this.updateProgress(20 + (this.retryCount * 20));
            this.showToast(`محاولة ${this.retryCount} من ${this.maxRetries}...`, 'info', 2000);

            const delay = Math.min(1000 * Math.pow(2, this.retryCount - 1), 8000);
            await new Promise(resolve => setTimeout(resolve, delay));

            await this.submitWithRetry(payload);
          } else {
            this.handleSubmitFailure(error);
          }
        }
      }

      async sendToAI(payload) {
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), this.requestTimeout);

        try {
          this.updateProgress(30);

          const response = await fetch('/api/analyze', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload),
            signal: controller.signal
          });

          this.updateProgress(70);

          if (!response.ok) {
            const errData = await response.json().catch(() => ({}));
            throw new Error(errData.error || `خطأ في الخادم (${response.status})`);
          }

          const result = await response.json();
          this.updateProgress(90);

          return result;
        } finally {
          clearTimeout(timeoutId);
        }
      }

      handleSubmitSuccess(result) {
        this.updateProgress(100);
        this.showToast('✅ تمت المعالجة بنجاح!', 'success', 2000);

        // حفظ النتيجة في sessionStorage
        try {
          const storageData = {
            text: result.text || '',
            meta: result.meta || {},
            timestamp: Date.now()
          };
          sessionStorage.setItem('analysis_result', JSON.stringify(storageData));
        } catch (e) {
          console.warn('sessionStorage error:', e);
        }

        // التوجيه لصفحة المراجعة بعد الإرسال الناجح
        setTimeout(() => {
          window.location.href = '/review';
        }, 500);
      }

      handleSubmitFailure(error) {
        this.showProgress(false);
        this.setSubmitting(false);

        let errorMsg = 'فشل الاتصال بالخادم. ';
        if (error.name === 'AbortError') {
          errorMsg += 'انتهت مهلة الاتصال. تحقق من سرعة الإنترنت.';
        } else if (error.message?.includes('NetworkError') || error.message?.includes('Failed to fetch')) {
          errorMsg += 'تعذر الاتصال بالإنترنت. حاول مرة أخرى.';
        } else {
          errorMsg += error.message || 'خطأ غير معروف';
        }

        this.showToast(errorMsg, 'error', 6000);
      }

      // ========== إعداد المستمعين ==========
      setupEventListeners() {
        // التقاط الصورة
        this.captureButton.addEventListener('click', () => this.captureImage());

        // رفع من المعرض
        this.attachBtn.addEventListener('click', () => this.imageInput.click());
        
        this.imageInput.addEventListener('change', (e) => {
          if (e.target.files[0]) {
            this.handleFileUpload(e.target.files[0]);
            e.target.value = '';
          }
        });

        // النقر على الصورة للعودة للكاميرا
        this.imagePreview.addEventListener('click', () => this.returnToCamera());

        // إزالة الصورة
        this.removeImageBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          this.returnToCamera();
          this.showToast('🗑️ تمت إزالة الصورة', 'info');
        });

        // تبديل الشبكة
        this.gridBtn.addEventListener('click', () => {
          this.gridOverlay.classList.toggle('active');
          this.showToast(
            this.gridOverlay.classList.contains('active') ? '🔲 الشبكة مفعلة' : '🔲 الشبكة معطلة',
            'info', 1500
          );
        });

        // زر الرجوع
        this.backButton.addEventListener('click', () => {
          if (this.capturedImageData) {
            if (confirm('لديك صورة غير مرسلة. هل تريد المغادرة؟')) {
              window.location.href = '/';
            }
          } else {
            window.location.href = '/';
          }
        });

        // زر الإرسال
        this.sendButton.addEventListener('click', () => this.handleSend());

        // إرسال بـ Enter
        this.messageBox.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            this.handleSend();
          }
        });

        // النقر المزدوج للتبديل بين الكاميرات
        this.cameraVideo.addEventListener('dblclick', () => {
          const newMode = this.facingMode === 'environment' ? 'user' : 'environment';
          this.startCamera(newMode);
          this.showToast(
            `📷 ${newMode === 'environment' ? 'الكاميرا الخلفية' : 'الكاميرا الأمامية'}`,
            'info', 1500
          );
        });

        // تنظيف عند المغادرة
        window.addEventListener('beforeunload', () => {
          if (this.currentStream) {
            this.currentStream.getTracks().forEach(track => track.stop());
          }
        });
      }

      // ========== تدمير ==========
      destroy() {
        if (this.currentStream) {
          this.currentStream.getTracks().forEach(track => track.stop());
          this.currentStream = null;
        }
        clearTimeout(this._toastTimeout);
        this.capturedImageData = null;
      }
    }

    // بدء التطبيق
    let app;
    document.addEventListener('DOMContentLoaded', () => {
      app = new LahzaCam();
      window.camApp = app;
    });

    // تنظيف عند المغادرة
    window.addEventListener('beforeunload', () => {
      if (app) app.destroy();
    });
  </script>
</body>
</html>
