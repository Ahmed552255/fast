            </div>
        </div>

        <!-- Footer -->
        <div class="app-footer">
            <span>Fast Sokon © 2025</span>
        </div>
    </div>

    <script is:inline>
        // ============================================
        // Fast Sokon - الصفحة الرئيسية v2.1
        // ✅ حل تضارب المزامنة باستخدام updatedAt
        // ✅ تحسينات أمان: التحقق من صحة الفواتير
        // ✅ قراءة الفواتير من السحابة أولاً (Cloud-First)
        // ============================================

        class FastSokonHome {
            constructor() {
                // Core services
                this.db = null;
                this.auth = null;
                this.firestore = null;
                this.rtdb = null;
                
                // State
                this.currentUser = null;
                this.profileData = null;
                this.broadcastChannel = null;
                this.unsubscribeAuth = null;
                this.unsubscribeRTDB = null;
                
                // Invoices data
                this.allInvoices = [];
                this.invoicesByDate = new Map();
                this.suppliersSet = new Set();
                
                // UI state
                this.selectedDate = new Date();
                this.selectedDateStr = this.formatDateStr(this.selectedDate);
                this.currentMonth = this.selectedDate.getMonth();
                this.currentYear = this.selectedDate.getFullYear();
                this.selectedSupplier = 'all';
                this.currentInvoiceId = null;
                this.isOnline = navigator.onLine;
                
                // Loading states
                this.loadingStates = new Set();
                
                // Cache
                this.cacheTimestamp = 0;
                this.CACHE_DURATION = 5000;
                
                // Constants
                this.DB_NAME = 'FastSokonDB';
                this.DB_VERSION = 8;
                this.MAX_INVOICE_ITEMS = 500;
                this.MAX_INVOICE_TOTAL = 1000000;
                
                // Initialize
                this.init();
            }

            async init() {
                try {
                    await this.waitForFirebase();
                    this.setupFirebase();
                    this.setupBroadcastChannel();
                    await this.openIndexedDB();
                    this.setupAuthListener();
                    this.setupEventListeners();
                    this.setupKeyboardShortcuts();
                    this.startOnlineMonitoring();
                    console.log('✅ Fast Sokon Home initialized');
                } catch (error) {
                    console.error('❌ Initialization failed:', error);
                }
            }

            // ========== Firebase Initialization ==========
            waitForFirebase() {
                return new Promise((resolve, reject) => {
                    if (typeof firebase !== 'undefined' && typeof firebaseConfig !== 'undefined') {
                        resolve();
                        return;
                    }
                    
                    let attempts = 0;
                    const maxAttempts = 100;
                    const check = () => {
                        attempts++;
                        if (typeof firebase !== 'undefined' && typeof firebaseConfig !== 'undefined') {
                            resolve();
                        } else if (attempts >= maxAttempts) {
                            reject(new Error('Firebase SDK failed to load'));
                        } else {
                            requestAnimationFrame(() => setTimeout(check, 50));
                        }
                    };
                    check();
                });
            }

            setupFirebase() {
                if (!firebase.apps.length) {
                    firebase.initializeApp(firebaseConfig);
                }
                this.auth = firebase.auth();
                this.firestore = firebase.firestore();
                this.rtdb = firebase.database();
                
                // Enable offline persistence
                this.firestore.enablePersistence({ synchronizeTabs: false }).catch(err => {
                    console.warn('Firestore persistence failed:', err.code);
                });
            }

            setupBroadcastChannel() {
                try {
                    this.broadcastChannel = new BroadcastChannel('fast_sokon_updates');
                    this.broadcastChannel.onmessage = async (event) => {
                        if (event.data.type === 'profile_update' && this.currentUser) {
                            await this.refreshProfileFromDB();
                        }
                        if (event.data.type === 'invoice_change' && this.currentUser) {
                            await this.refreshData();
                        }
                    };
                } catch (e) {
                    console.warn('BroadcastChannel not supported, using localStorage fallback');
                    window.addEventListener('storage', async (e) => {
                        if (e.key === 'profile_update' && this.currentUser) {
                            await this.refreshProfileFromDB();
                        }
                        if (e.key === 'invoice_change' && this.currentUser) {
                            await this.refreshData();
                        }
                    });
                }
            }

            // ========== IndexedDB Operations ==========
            openIndexedDB() {
                return new Promise((resolve, reject) => {
                    const request = indexedDB.open(this.DB_NAME, this.DB_VERSION);
                    
                    request.onupgradeneeded = (e) => {
                        const db = e.target.result;
                        
                        if (!db.objectStoreNames.contains('invoices')) {
                            const store = db.createObjectStore('invoices', { keyPath: 'id' });
                            store.createIndex('date', 'dateStr');
                            store.createIndex('supplier', 'supplier');
                            store.createIndex('updatedAt', 'updatedAt');
                        }
                        
                        if (!db.objectStoreNames.contains('profile')) {
                            db.createObjectStore('profile', { keyPath: 'uid' });
                        }
                        
                        if (!db.objectStoreNames.contains('saved_accounts')) {
                            db.createObjectStore('saved_accounts', { keyPath: 'uid' });
                        }
                    };
                    
                    request.onsuccess = (e) => {
                        this.db = e.target.result;
                        this.db.onclose = () => console.warn('IndexedDB connection closed unexpectedly');
                        resolve();
                    };
                    
                    request.onerror = () => reject(request.error);
                    request.onblocked = () => console.warn('IndexedDB blocked. Please close other tabs.');
                });
            }

            async getFromDB(store, key) {
                if (!this.db) return null;
                return new Promise((resolve) => {
                    try {
                        const tx = this.db.transaction(store, 'readonly');
                        const req = tx.objectStore(store).get(key);
                        req.onsuccess = () => resolve(req.result || null);
                        req.onerror = () => resolve(null);
                    } catch (e) {
                        resolve(null);
                    }
                });
            }

            async putToDB(store, data) {
                if (!this.db) return;
                return new Promise((resolve) => {
                    try {
                        const tx = this.db.transaction(store, 'readwrite');
                        tx.objectStore(store).put(data);
                        tx.oncomplete = () => resolve();
                    } catch (e) {
                        resolve();
                    }
                });
            }

            async getAllFromDB(store) {
                if (!this.db) return [];
                return new Promise((resolve) => {
                    try {
                        const tx = this.db.transaction(store, 'readonly');
                        const req = tx.objectStore(store).getAll();
                        req.onsuccess = () => resolve(req.result || []);
                        req.onerror = () => resolve([]);
                    } catch (e) {
                        resolve([]);
                    }
                });
            }

            async deleteFromDB(store, key) {
                if (!this.db) return;
                return new Promise((resolve) => {
                    try {
                        const tx = this.db.transaction(store, 'readwrite');
                        tx.objectStore(store).delete(key);
                        tx.oncomplete = () => resolve();
                    } catch (e) {
                        resolve();
                    }
                });
            }

            // ========== Validation (أمان) ==========
            /**
             * التحقق من صحة بيانات الفاتورة قبل الحفظ
             * @param {Object} invoice - كائن الفاتورة
             * @returns {boolean} - صحة البيانات
             */
            validateInvoice(invoice) {
                if (!invoice || typeof invoice !== 'object') {
                    console.warn('❌ فشل التحقق: الفاتورة غير موجودة أو ليست كائنًا');
                    return false;
                }

                // 1. الحقول الإلزامية
                const required = ['id', 'supplier', 'total', 'items', 'dateStr'];
                for (const field of required) {
                    if (invoice[field] === undefined || invoice[field] === null) {
                        console.warn(`❌ فشل التحقق: الحقل "${field}" مفقود`);
                        return false;
                    }
                }

                // 2. نوع المورد
                if (typeof invoice.supplier !== 'string' || invoice.supplier.trim().length === 0) {
                    console.warn('❌ فشل التحقق: اسم المورد غير صالح');
                    return false;
                }

                // 3. صحة التاريخ
                if (!/^\d{4}-\d{2}-\d{2}$/.test(invoice.dateStr)) {
                    console.warn('❌ فشل التحقق: تنسيق التاريخ غير صالح');
                    return false;
                }

                // 4. التحقق من المصفوفة items
                if (!Array.isArray(invoice.items)) {
                    console.warn('❌ فشل التحقق: الأصناف ليست مصفوفة');
                    return false;
                }

                // 5. حد أقصى لعدد الأصناف (لمنع إساءة الاستخدام)
                if (invoice.items.length > this.MAX_INVOICE_ITEMS) {
                    console.warn(`❌ فشل التحقق: عدد الأصناف (${invoice.items.length}) يتجاوز الحد المسموح (${this.MAX_INVOICE_ITEMS})`);
                    return false;
                }

                // 6. التحقق من صحة كل صنف
                for (let i = 0; i < invoice.items.length; i++) {
                    const item = invoice.items[i];
                    if (!item || typeof item !== 'object') {
                        console.warn(`❌ فشل التحقق: الصنف #${i} غير صالح`);
                        return false;
                    }
                    if (!item.name || typeof item.name !== 'string' || item.name.trim().length === 0) {
                        console.warn(`❌ فشل التحقق: الصنف #${i} ليس له اسم`);
                        return false;
                    }
                    const itemPrice = parseFloat(item.price);
                    if (isNaN(itemPrice) || itemPrice < 0) {
                        console.warn(`❌ فشل التحقق: سعر الصنف #${i} غير صالح`);
                        return false;
                    }
                    const itemQty = parseInt(item.quantity) || 1;
                    if (itemQty < 1 || itemQty > 10000) {
                        console.warn(`❌ فشل التحقق: كمية الصنف #${i} غير صالحة`);
                        return false;
                    }
                }

                // 7. التحقق من قيمة الإجمالي
                const total = parseFloat(invoice.total);
                if (isNaN(total) || total < 0 || total > this.MAX_INVOICE_TOTAL) {
                    console.warn(`❌ فشل التحقق: قيمة الإجمالي (${total}) غير صالحة`);
                    return false;
                }

                return true;
            }

            // ========== Profile Management ==========
            async loadProfileFromDB(uid) {
                try {
                    let profile = await this.getFromDB('profile', uid);
                    if (!profile && this.currentUser) {
                        profile = {
                            uid: uid,
                            email: this.currentUser.email || '',
                            alias: this.currentUser.displayName || this.currentUser.email?.split('@')[0] || 'مستخدم',
                            photoURL: this.currentUser.photoURL || '',
                            lastLogin: Date.now()
                        };
                        await this.putToDB('profile', profile);
                    }
                    return profile;
                } catch (e) {
                    console.error('Error loading profile:', e);
                    return null;
                }
            }

            async refreshProfileFromDB() {
                if (!this.currentUser) return;
                this.profileData = await this.loadProfileFromDB(this.currentUser.uid);
                this.updateProfileUI();
            }

            updateProfileUI() {
                const avatarEl = document.getElementById('profileAvatar');
                const nameEl = document.getElementById('profileName');
                
                if (!avatarEl || !nameEl) return;
                
                if (this.currentUser && this.profileData) {
                    const displayName = this.profileData.alias || 
                                       this.currentUser.displayName || 
                                       (this.currentUser.email?.split('@')[0] || 'مستخدم');
                    
                    nameEl.textContent = displayName.length > 12 ? 
                                        displayName.slice(0, 10) + '...' : 
                                        displayName;
                    
                    const photoUrl = this.profileData.photoURL || '';
                    
                    if (photoUrl && (photoUrl.startsWith('data:image') || photoUrl.startsWith('http'))) {
                        avatarEl.innerHTML = `<img src="${photoUrl}" alt="${this.escapeHtml(displayName)}" loading="lazy">`;
                        avatarEl.style.background = 'none';
                    } else {
                        avatarEl.innerHTML = displayName.charAt(0).toUpperCase();
                        avatarEl.style.background = 'linear-gradient(135deg, #9d8cff, #6b5bdb)';
                    }
                } else {
                    nameEl.textContent = 'الملف الشخصي';
                    avatarEl.innerHTML = '👤';
                    avatarEl.style.background = 'none';
                }
            }

            // ========== Invoices Management (Cloud-First) ==========
            
            /**
             * تحميل الفواتير من السحابة (Firestore) - المصدر الأساسي
             */
            async loadInvoicesFromCloud() {
                if (!this.firestore || !this.currentUser) return [];
                
                try {
                    const snapshot = await this.firestore
                        .collection('users')
                        .doc(this.currentUser.uid)
                        .collection('invoices')
                        .get();
                    
                    const cloudInvoices = [];
                    snapshot.forEach(doc => {
                        const data = doc.data();
                        cloudInvoices.push({ 
                            id: doc.id, 
                            ...data,
                            // ضمان وجود updatedAt (للبيانات القديمة)
                            updatedAt: data.updatedAt || 0
                        });
                    });
                    return cloudInvoices;
                } catch (e) {
                    console.warn('Cloud load failed:', e);
                    return [];
                }
            }

            /**
             * تحميل الفواتير من التخزين المحلي (للوضع غير المتصل فقط)
             */
            async loadInvoicesFromLocal() {
                return await this.getAllFromDB('invoices');
            }

            /**
             * مزامنة فاتورة إلى السحابة
             */
            async syncInvoiceToCloud(invoice) {
                if (!this.firestore || !this.currentUser) return false;
                
                try {
                    // التأكد من وجود updatedAt
                    if (!invoice.updatedAt) {
                        invoice.updatedAt = Date.now();
                    }
                    
                    await this.firestore
                        .collection('users')
                        .doc(this.currentUser.uid)
                        .collection('invoices')
                        .doc(invoice.id)
                        .set(invoice, { merge: true });
                    return true;
                } catch (e) {
                    console.warn('Cloud sync failed:', e);
                    return false;
                }
            }

            /**
             * حفظ فاتورة (Cloud-First مع تحقق)
             */
            async saveInvoice(invoice) {
                // 1. التحقق من صحة البيانات
                if (!this.validateInvoice(invoice)) {
                    throw new Error('بيانات الفاتورة غير صالحة - تم رفض الحفظ');
                }

                // 2. إضافة طابع زمني للتحديث
                invoice.updatedAt = Date.now();

                // 3. حفظ محلي سريع (للاستجابة الفورية والنسخ الاحتياطي)
                await this.putToDB('invoices', invoice);

                // 4. مزامنة إلى السحابة مع حل التضارب
                if (this.isOnline && this.firestore && this.currentUser) {
                    try {
                        // جلب النسخة السحابية الحالية للمقارنة
                        const cloudDoc = await this.firestore
                            .collection('users')
                            .doc(this.currentUser.uid)
                            .collection('invoices')
                            .doc(invoice.id)
                            .get();

                        if (cloudDoc.exists) {
                            const cloudData = cloudDoc.data();
                            const cloudUpdatedAt = cloudData.updatedAt || 0;
                            const localUpdatedAt = invoice.updatedAt || 0;

                            // حل التضارب: الأحدث يفوز
                            if (cloudUpdatedAt > localUpdatedAt) {
                                console.warn('⚠️ النسخة السحابية أحدث، لم يتم استبدالها. حفظ محلي فقط.');
                                // تحديث النسخة المحلية بالنسخة السحابية الأحدث
                                const mergedInvoice = { id: cloudDoc.id, ...cloudData };
                                await this.putToDB('invoices', mergedInvoice);
                                return mergedInvoice;
                            }
                        }

                        // النسخة المحلية هي الأحدث أو غير موجودة سحابياً
                        await this.syncInvoiceToCloud(invoice);
                    } catch (e) {
                        console.warn('⚠️ فشلت المزامعة السحابية، محفوظة محلياً:', e.message);
                    }
                }

                return invoice;
            }

            /**
             * حذف فاتورة (Cloud-First)
             */
            async deleteInvoice(invoiceId) {
                if (!confirm('هل أنت متأكد من حذف هذه الفاتورة؟')) return false;
                
                let cloudDeleted = false;
                
                // 1. حذف من السحابة أولاً
                if (this.isOnline && this.firestore && this.currentUser) {
                    try {
                        await this.firestore
                            .collection('users')
                            .doc(this.currentUser.uid)
                            .collection('invoices')
                            .doc(invoiceId)
                            .delete();
                        cloudDeleted = true;
                    } catch (e) {
                        console.warn('Cloud delete failed:', e);
                    }
                }
                
                // 2. حذف من التخزين المحلي دائماً
                await this.deleteFromDB('invoices', invoiceId);
                
                // 3. تحديث القائمة
                await this.refreshData();
                
                return true;
            }

            // ========== Data Sync & Refresh (Cloud-First مع updatedAt) ==========
            
            /**
             * تحديث البيانات: السحابة أولاً، مع حل التضارب باستخدام updatedAt
             */
            async refreshData() {
                this.setSyncStatus('syncing', 'جاري المزامنة...');
                
                if (this.isOnline && this.currentUser) {
                    try {
                        // 1. جلب الفواتير من السحابة (المصدر الأساسي)
                        const cloudInvoices = await this.loadInvoicesFromCloud();
                        const cloudMap = new Map(cloudInvoices.map(inv => [inv.id, inv]));
                        
                        // 2. جلب الفواتير المحلية (للمقارنة ورفع الجديد منها)
                        const localInvoices = await this.loadInvoicesFromLocal();
                        const localMap = new Map(localInvoices.map(inv => [inv.id, inv]));
                        
                        // 3. تحديث التخزين المحلي بالبيانات السحابية مع حل التضارب
                        for (const [id, cloudInv] of cloudMap) {
                            const localInv = localMap.get(id);
                            
                            if (!localInv) {
                                // موجودة سحابياً فقط → حفظ محلي
                                await this.putToDB('invoices', cloudInv);
                            } else {
                                // موجودة في كلا المكانين → المقارنة بـ updatedAt
                                const cloudUpdatedAt = cloudInv.updatedAt || 0;
                                const localUpdatedAt = localInv.updatedAt || 0;
                                
                                if (cloudUpdatedAt >= localUpdatedAt) {
                                    // السحابية أحدث أو متساوية → استخدام السحابية
                                    await this.putToDB('invoices', cloudInv);
                                }
                                // إذا المحلية أحدث → ستبقى محلياً وسيتم رفعها لاحقاً
                            }
                        }
                        
                        // 4. رفع الفواتير المحلية الأحدث أو غير الموجودة سحابياً
                        for (const [id, localInv] of localMap) {
                            const cloudInv = cloudMap.get(id);
                            
                            if (!cloudInv) {
                                // غير موجودة سحابياً → رفعها
                                await this.syncInvoiceToCloud(localInv);
                                await this.putToDB('invoices', localInv);
                            } else {
                                const cloudUpdatedAt = cloudInv.updatedAt || 0;
                                const localUpdatedAt = localInv.updatedAt || 0;
                                
                                if (localUpdatedAt > cloudUpdatedAt) {
                                    // المحلية أحدث → رفعها للسحابة
                                    await this.syncInvoiceToCloud(localInv);
                                    await this.putToDB('invoices', localInv);
                                }
                            }
                        }
                        
                        // 5. تعيين جميع الفواتير من التخزين المحلي المحدث
                        this.allInvoices = await this.loadInvoicesFromLocal();
                        
                    } catch (e) {
                        console.warn('⚠️ فشلت المزامعة السحابية، استخدام التخزين المحلي:', e.message);
                        this.allInvoices = await this.loadInvoicesFromLocal();
                    }
                } else {
                    // وضع غير متصل: استخدام التخزين المحلي فقط
                    this.allInvoices = await this.loadInvoicesFromLocal();
                }
                
                // تحديث الذاكرة المؤقتة
                this.updateCaches();
                this.setSyncStatus(this.isOnline ? 'online' : 'offline');
            }

            updateCaches() {
                this.invoicesByDate.clear();
                this.suppliersSet.clear();
                
                this.allInvoices.forEach(inv => {
                    if (inv.dateStr) {
                        if (!this.invoicesByDate.has(inv.dateStr)) {
                            this.invoicesByDate.set(inv.dateStr, []);
                        }
                        this.invoicesByDate.get(inv.dateStr).push(inv);
                    }
                    if (inv.supplier) {
                        this.suppliersSet.add(inv.supplier);
                    }
                });
            }

            // ========== UI Rendering ==========
            setSyncStatus(status, customMessage = null) {
                this.isOnline = status !== 'offline';
                const statusEl = document.getElementById('syncStatus');
                if (!statusEl) return;
                
                let icon, text, className;
                
                if (status === 'online') {
                    icon = 'fa-cloud-upload-alt';
                    text = 'متزامن';
                    className = 'online';
                } else if (status === 'syncing') {
                    icon = 'fa-sync-alt fa-spin';
                    text = customMessage || 'جاري المزامنة...';
                    className = 'syncing';
                } else {
                    icon = 'fa-cloud-slash';
                    text = 'غير متصل';
                    className = 'offline';
                }
                
                statusEl.innerHTML = `<i class="fas ${icon}" aria-hidden="true"></i><span>${text}</span>`;
                statusEl.className = `sync-status ${className}`;
            }

            // ========== Auth Listener ==========
            setupAuthListener() {
                this.unsubscribeAuth = this.auth.onAuthStateChanged(async (user) => {
                    this.currentUser = user;
                    
                    if (user) {
                        this.profileData = await this.loadProfileFromDB(user.uid);
                        this.updateProfileUI();
                        this.setupRealtimeSync();
                        await this.refreshData();
                    } else {
                        this.profileData = null;
                        this.updateProfileUI();
                        this.allInvoices = [];
                        this.updateCaches();
                        this.setSyncStatus('offline');
                    }
                });
            }

            setupRealtimeSync() {
                if (!this.rtdb || !this.currentUser) return;
                
                // Cleanup previous listener
                if (this.unsubscribeRTDB) {
                    this.rtdb.ref(`users/${this.currentUser.uid}/profile`).off('value', this.unsubscribeRTDB);
                }
                
                // Listen for profile updates from profile page
                this.unsubscribeRTDB = this.rtdb.ref(`users/${this.currentUser.uid}/profile`).on('value', async (snapshot) => {
                    if (snapshot.exists()) {
                        const cloudProfile = snapshot.val();
                        const profile = await this.getFromDB('profile', this.currentUser.uid);
                        if (profile) {
                            profile.alias = cloudProfile.alias || profile.alias;
                            profile.photoURL = cloudProfile.photoURL || profile.photoURL;
                            await this.putToDB('profile', profile);
                            this.profileData = profile;
                            this.updateProfileUI();
                        }
                    }
                });
            }

            // ========== Event Listeners ==========
            setupEventListeners() {
                // Navigation
                document.getElementById('profileBtn')?.addEventListener('click', () => {
                    window.location.href = '/profile';
                });
                
                document.getElementById('cameraBtn')?.addEventListener('click', () => {
                    window.location.href = '/camera';
                });
            }

            setupKeyboardShortcuts() {
                document.addEventListener('keydown', (e) => {
                    if (e.key === 'Escape') {
                        // لا توجد نماذج مفتوحة لإغلاقها حالياً
                    }
                });
            }

            startOnlineMonitoring() {
                window.addEventListener('online', () => {
                    this.setSyncStatus('syncing');
                    this.refreshData();
                });
                
                window.addEventListener('offline', () => {
                    this.setSyncStatus('offline');
                });
                
                // Initial status
                this.setSyncStatus(navigator.onLine ? 'online' : 'offline');
            }

            // ========== Utility Functions ==========
            formatDateStr(date) {
                return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
            }

            escapeHtml(str) {
                if (!str) return '';
                const div = document.createElement('div');
                div.textContent = str;
                return div.innerHTML;
            }

            // ========== Cleanup ==========
            destroy() {
                // Close BroadcastChannel
                if (this.broadcastChannel) {
                    this.broadcastChannel.close();
                    this.broadcastChannel = null;
                }
                
                // Unsubscribe from Firebase Auth
                if (this.unsubscribeAuth) {
                    this.unsubscribeAuth();
                    this.unsubscribeAuth = null;
                }
                
                // Unsubscribe from Realtime Database
                if (this.unsubscribeRTDB && this.rtdb && this.currentUser) {
                    this.rtdb.ref(`users/${this.currentUser.uid}/profile`).off('value', this.unsubscribeRTDB);
                    this.unsubscribeRTDB = null;
                }
                
                // Close IndexedDB
                if (this.db) {
                    this.db.close();
                    this.db = null;
                }
                
                console.log('✅ Fast Sokon Home destroyed');
            }
        }

        // Initialize application
        let app;
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', () => {
                app = new FastSokonHome();
                window.app = app;
            });
        } else {
            app = new FastSokonHome();
            window.app = app;
        }

        // Cleanup on page unload
        window.addEventListener('beforeunload', () => {
            if (app) app.destroy();
        });
        
        window.addEventListener('pagehide', () => {
            if (app) app.destroy();
        });
    </script>
</body>
</html>
