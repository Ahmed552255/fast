<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Fast Sokon | مساعد الصيدلي الذكي</title>
    
    <!-- Critical CSS inline -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" media="print" onload="this.media='all'">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    
    <!-- Firebase SDKs - deferred loading for performance -->
    <script is:inline src="https://www.gstatic.com/firebasejs/9.22.2/firebase-app-compat.js" defer></script>
    <script is:inline src="https://www.gstatic.com/firebasejs/9.22.2/firebase-firestore-compat.js" defer></script>
    <script is:inline src="https://www.gstatic.com/firebasejs/9.22.2/firebase-auth-compat.js" defer></script>
    <script is:inline src="https://www.gstatic.com/firebasejs/9.22.2/firebase-database-compat.js" defer></script>
    <script is:inline src="/firebase-config.js" defer></script>

    <style is:global>
        :root {
            --bg-start: #0a0a1a;
            --bg-end: #12102a;
            --card-bg: rgba(20, 18, 38, 0.85);
            --border-light: rgba(255, 255, 255, 0.08);
            --border-glow: rgba(255, 255, 255, 0.12);
            --purple: #9d8cff;
            --purple-dark: #6b5bdb;
            --purple-glow: rgba(157, 140, 255, 0.2);
            --gold: #ffd966;
            --gold-dark: #e6c450;
            --text-white: #ffffff;
            --text-dim: rgba(255, 255, 255, 0.7);
            --text-muted: rgba(255, 255, 255, 0.4);
            --danger: #ff6b6b;
            --success: #51cf66;
            --radius-xl: 28px;
            --radius-lg: 20px;
            --radius-md: 16px;
            --radius-sm: 12px;
            --shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
            --transition-fast: 0.15s cubic-bezier(0.4, 0, 0.2, 1);
            --transition-normal: 0.25s ease;
            --font-family: 'Cairo', system-ui, -apple-system, sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: var(--font-family);
            background: linear-gradient(135deg, var(--bg-start), var(--bg-end));
            min-height: 100vh;
            min-height: 100dvh;
            color: var(--text-white);
            padding: 12px;
            position: relative;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 20% 30%, var(--purple-glow), transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        .app {
            max-width: 500px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        /* Header */
        .header {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            padding: 12px 18px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: var(--shadow);
            transform: translateZ(0);
        }

        .logo {
            display: flex;
            align-items: baseline;
            gap: 6px;
        }

        .logo-icon {
            font-size: 26px;
            background: linear-gradient(135deg, var(--purple), var(--gold));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .logo-text {
            font-size: 20px;
            font-weight: 800;
            background: linear-gradient(135deg, #fff, var(--purple));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .profile-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border-glow);
            border-radius: var(--radius-sm);
            padding: 6px 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: var(--transition-fast);
            font-family: inherit;
            color: inherit;
            transform: translateZ(0);
            will-change: transform;
        }

        .profile-btn:active {
            transform: scale(0.97);
            background: rgba(255, 255, 255, 0.1);
        }

        .profile-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--purple), var(--purple-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            overflow: hidden;
            flex-shrink: 0;
        }

        .profile-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .profile-name {
            font-size: 14px;
            font-weight: 600;
            max-width: 110px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            color: var(--text-dim);
        }

        /* Camera Card */
        .camera-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-xl);
            padding: 16px;
            box-shadow: var(--shadow);
        }

        .camera-btn {
            width: 100%;
            background: linear-gradient(135deg, rgba(157, 140, 255, 0.15), rgba(255, 217, 102, 0.08));
            border: 1px solid var(--purple);
            color: var(--purple);
            padding: 16px;
            border-radius: var(--radius-md);
            font-size: 16px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            cursor: pointer;
            transition: var(--transition-fast);
            font-family: inherit;
            transform: translateZ(0);
            will-change: transform;
        }

        .camera-btn:active {
            transform: scale(0.98);
            background: linear-gradient(135deg, rgba(157, 140, 255, 0.25), rgba(255, 217, 102, 0.15));
        }

        /* Invoices Section */
        .invoices-section {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-xl);
            padding: 16px;
            box-shadow: var(--shadow);
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 14px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .section-title i {
            color: var(--purple);
        }

        .sync-status {
            font-size: 11px;
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: var(--radius-sm);
            transition: var(--transition-fast);
        }

        .sync-status.online {
            color: var(--success);
        }

        .sync-status.offline {
            color: var(--danger);
        }

        .sync-status.syncing {
            color: var(--purple);
        }

        .date-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border-glow);
            border-radius: var(--radius-sm);
            padding: 8px 16px;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: var(--transition-fast);
            font-family: inherit;
            color: var(--text-dim);
            width: 100%;
            justify-content: center;
            transform: translateZ(0);
            will-change: transform;
        }

        .date-btn:active {
            transform: scale(0.97);
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-bottom: 20px;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-glow);
            border-radius: var(--radius-md);
            padding: 12px 8px;
            text-align: center;
            transition: var(--transition-fast);
            transform: translateZ(0);
            will-change: transform;
        }

        .stat-card:active {
            transform: scale(0.98);
        }

        .stat-icon {
            font-size: 22px;
            color: var(--purple);
            margin-bottom: 6px;
        }

        .stat-label {
            font-size: 11px;
            color: var(--text-muted);
            margin-bottom: 4px;
        }

        .stat-value {
            font-size: 20px;
            font-weight: 800;
            color: var(--gold);
        }

        .stat-unit {
            font-size: 10px;
            color: var(--text-muted);
        }

        /* Invoices List */
        .invoices-list {
            max-height: 45vh;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
            -webkit-overflow-scrolling: touch;
        }

        .invoices-list::-webkit-scrollbar {
            width: 4px;
        }

        .invoices-list::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 4px;
        }

        .invoices-list::-webkit-scrollbar-thumb {
            background: var(--purple);
            border-radius: 4px;
        }

        .invoice-item {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-glow);
            border-radius: var(--radius-md);
            padding: 12px;
            cursor: pointer;
            transition: var(--transition-fast);
            position: relative;
            transform: translateZ(0);
            will-change: transform;
        }

        .invoice-item:active {
            transform: scale(0.99);
            background: rgba(255, 255, 255, 0.06);
        }

        .invoice-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .supplier {
            font-weight: 700;
            font-size: 15px;
            color: var(--purple);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .time {
            font-size: 11px;
            color: var(--text-muted);
        }

        .invoice-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .items-count {
            font-size: 12px;
            color: var(--text-dim);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .total {
            font-size: 16px;
            font-weight: 800;
            color: var(--gold);
        }

        .delete-btn {
            position: absolute;
            top: 8px;
            left: 8px;
            background: rgba(255, 107, 107, 0.15);
            border: 1px solid rgba(255, 107, 107, 0.3);
            border-radius: var(--radius-sm);
            width: 28px;
            height: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition-fast);
            transform: translateZ(0);
            will-change: transform;
        }

        .delete-btn:active {
            transform: scale(0.95);
            background: rgba(255, 107, 107, 0.3);
        }

        .delete-btn i {
            color: var(--danger);
            font-size: 12px;
        }

        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: var(--text-muted);
        }

        .empty-state i {
            font-size: 48px;
            margin-bottom: 12px;
            opacity: 0.5;
        }

        /* Modals - محسنة للأداء */
        .modal {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            padding: 16px;
            visibility: hidden;
            opacity: 0;
            pointer-events: none;
            transition: opacity var(--transition-normal), visibility var(--transition-normal);
            will-change: opacity;
        }

        .modal.active {
            visibility: visible;
            opacity: 1;
            pointer-events: auto;
        }

        .modal-content {
            background: linear-gradient(135deg, rgba(20, 18, 38, 0.98), rgba(16, 14, 32, 0.98));
            border: 1px solid var(--border-light);
            border-radius: var(--radius-xl);
            width: 100%;
            max-width: 450px;
            max-height: 85vh;
            overflow-y: auto;
            transform: scale(0.95);
            transition: transform var(--transition-normal);
            -webkit-overflow-scrolling: touch;
        }

        .modal.active .modal-content {
            transform: scale(1);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 18px 20px;
            border-bottom: 1px solid var(--border-light);
            position: sticky;
            top: 0;
            background: inherit;
            z-index: 1;
            backdrop-filter: blur(10px);
        }

        .modal-title {
            font-size: 18px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .modal-close {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border-glow);
            border-radius: var(--radius-sm);
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition-fast);
            color: var(--text-dim);
            font-family: inherit;
        }

        .modal-close:active {
            transform: scale(0.95);
        }

        .modal-body {
            padding: 20px;
        }

        /* Calendar Styles */
        .filter-select {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border-glow);
            border-radius: var(--radius-md);
            padding: 12px 16px;
            color: var(--text-white);
            font-family: inherit;
            font-size: 14px;
            cursor: pointer;
            margin-bottom: 20px;
            outline: none;
            transition: var(--transition-fast);
        }

        .filter-select:focus {
            border-color: var(--purple);
            box-shadow: 0 0 10px var(--purple-glow);
        }

        .calendar-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .month-text {
            font-size: 18px;
            font-weight: 700;
            user-select: none;
        }

        .nav-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border-glow);
            border-radius: var(--radius-sm);
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition-fast);
            color: var(--text-dim);
            font-family: inherit;
            transform: translateZ(0);
        }

        .nav-btn:active {
            transform: scale(0.95);
        }

        .weekdays {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            text-align: center;
            margin-bottom: 10px;
            font-size: 12px;
            color: var(--text-muted);
            user-select: none;
        }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 6px;
        }

        .calendar-day {
            aspect-ratio: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.03);
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            position: relative;
            transition: var(--transition-fast);
            transform: translateZ(0);
            will-change: transform;
            user-select: none;
        }

        .calendar-day:active {
            transform: scale(0.95);
            background: rgba(255, 255, 255, 0.08);
        }

        .calendar-day.today {
            border: 2px solid var(--gold);
            color: var(--gold);
        }

        .calendar-day.selected {
            background: linear-gradient(135deg, var(--purple), var(--purple-dark));
            color: white;
        }

        .calendar-day.has-invoices::after {
            content: '';
            position: absolute;
            bottom: 4px;
            width: 4px;
            height: 4px;
            border-radius: 50%;
            background: var(--gold);
        }

        .calendar-hint {
            margin-top: 16px;
            font-size: 11px;
            color: var(--text-muted);
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .hint-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--gold);
        }

        /* Invoice Detail Styles */
        .detail-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid var(--border-light);
        }

        .detail-label {
            color: var(--text-muted);
            font-size: 14px;
        }

        .detail-value {
            font-weight: 600;
            font-size: 14px;
        }

        .items-list {
            margin-top: 16px;
        }

        .items-title {
            font-weight: 700;
            margin-bottom: 12px;
            font-size: 14px;
            color: var(--purple);
        }

        .item-row {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-glow);
            border-radius: var(--radius-sm);
            padding: 10px;
            margin-bottom: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .item-name {
            font-weight: 600;
            font-size: 14px;
        }

        .item-price {
            font-size: 13px;
            color: var(--gold);
        }

        .detail-total {
            margin-top: 20px;
            padding-top: 16px;
            border-top: 2px solid var(--border-light);
            text-align: center;
            font-size: 18px;
            font-weight: 800;
            color: var(--gold);
        }

        .delete-detail-btn {
            width: 100%;
            margin-top: 20px;
            background: rgba(255, 107, 107, 0.15);
            border: 1px solid var(--danger);
            color: var(--danger);
            padding: 12px;
            border-radius: var(--radius-md);
            font-size: 14px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            cursor: pointer;
            transition: var(--transition-fast);
            font-family: inherit;
            transform: translateZ(0);
            will-change: transform;
        }

        .delete-detail-btn:active {
            transform: scale(0.98);
            background: rgba(255, 107, 107, 0.25);
        }

        /* Loading Spinner */
        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* تحسينات للهواتف الضعيفة */
        @media (max-width: 380px) {
            body {
                padding: 8px;
            }
            
            .stat-value {
                font-size: 16px;
            }
            
            .profile-name {
                display: none;
            }
            
            .calendar-day {
                font-size: 12px;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                animation-duration: 0.01ms !important;
                transition-duration: 0.01ms !important;
            }
        }

        .hidden {
            display: none !important;
        }
    </style>
</head>
<body>
    <div class="app">
        <!-- Header -->
        <div class="header">
            <div class="logo" aria-label="Fast Sokon">
                <i class="fas fa-capsules logo-icon" aria-hidden="true"></i>
                <span class="logo-text">Fast Sokon</span>
            </div>
            <button class="profile-btn" id="profileBtn" aria-label="الملف الشخصي">
                <div class="profile-avatar" id="profileAvatar">👤</div>
                <span class="profile-name" id="profileName">الملف الشخصي</span>
            </button>
        </div>

        <!-- Camera Section -->
        <div class="camera-card">
            <button class="camera-btn" id="cameraBtn" aria-label="مسح فاتورة جديدة">
                <i class="fas fa-camera-retro fa-lg" aria-hidden="true"></i>
                مسح فاتورة جديدة
            </button>
        </div>

        <!-- Invoices Section -->
        <div class="invoices-section">
            <div class="section-header">
                <div class="section-title">
                    <i class="fas fa-file-invoice" aria-hidden="true"></i>
                    <span>الفواتير</span>
                </div>
                <div class="sync-status offline" id="syncStatus" role="status" aria-live="polite">
                    <i class="fas fa-cloud-slash" aria-hidden="true"></i>
                    <span>غير متصل</span>
                </div>
            </div>

            <div class="section-header">
                <button class="date-btn" id="dateBtn" aria-label="اختيار التاريخ">
                    <i class="fas fa-calendar-alt" aria-hidden="true"></i>
                    <span id="currentDateText"></span>
                    <i class="fas fa-chevron-down" aria-hidden="true"></i>
                </button>
            </div>

            <!-- Stats -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-receipt" aria-hidden="true"></i></div>
                    <div class="stat-label">الفواتير</div>
                    <div class="stat-value" id="statInvoices">0</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-cubes" aria-hidden="true"></i></div>
                    <div class="stat-label">الأصناف</div>
                    <div class="stat-value" id="statItems">0</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-money-bill-wave" aria-hidden="true"></i></div>
                    <div class="stat-label">الإجمالي</div>
                    <div class="stat-value" id="statTotal">0</div>
                    <span class="stat-unit">ج.م</span>
                </div>
            </div>

            <!-- Invoices List -->
            <div class="invoices-list" id="invoicesList">
                <div class="empty-state">
                    <i class="fas fa-inbox" aria-hidden="true"></i>
                    <p>لا توجد فواتير لهذا اليوم</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Calendar Modal -->
    <div class="modal" id="calendarModal" role="dialog" aria-modal="true" aria-label="اختيار التاريخ">
        <div class="modal-content">
            <div class="modal-header">
                <div class="modal-title">
                    <i class="fas fa-calendar-alt" aria-hidden="true"></i>
                    <span>اختر تاريخ</span>
                </div>
                <button class="modal-close" id="closeCalendarModal" aria-label="إغلاق">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
                <select class="filter-select" id="supplierFilter" aria-label="فلترة حسب المورد">
                    <option value="all">🔍 جميع الموردين</option>
                </select>
                
                <div class="calendar-nav">
                    <button class="nav-btn" id="prevMonth" aria-label="الشهر السابق">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                    <div class="month-text" id="monthText" aria-live="polite"></div>
                    <button class="nav-btn" id="nextMonth" aria-label="الشهر التالي">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                </div>
                
                <div class="weekdays">
                    <span>أحد</span><span>إثنين</span><span>ثلاثاء</span>
                    <span>أربعاء</span><span>خميس</span><span>جمعة</span><span>سبت</span>
                </div>
                <div class="calendar-grid" id="calendarGrid"></div>
                
                <div class="calendar-hint">
                    <div class="hint-dot"></div>
                    <span>أيام تحتوي على فواتير</span>
